# Copy to .env and fill in. Expo inlines EXPO_PUBLIC_* vars at build time.

# Firebase web config (same project as the web app: soldierwallet-16c61)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=soldierwallet-16c61.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=soldierwallet-16c61
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=soldierwallet-16c61.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=896637134400
EXPO_PUBLIC_FIREBASE_APP_ID=

# OTP backend base URL (the Express server in ../backend).
# Use your machine's LAN IP so a physical phone can reach it, e.g. http://192.168.1.20:3001
# Leave blank to skip OTP verification (signup proceeds without SMS).
EXPO_PUBLIC_API_BASE=
