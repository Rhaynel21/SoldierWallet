# Firebase WEB app config for SoldierWallet (project: soldierwallet-16c61)
# 1. Firebase Console > Project settings > General > "Your apps"
# 2. Click the </> (Web) icon to register a Web app (name it e.g. "SoldierWallet Web")
# 3. Copy the config values into a file named  .env  (copy of this file)
#
# Only VITE_-prefixed vars are exposed to the app.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=soldierwallet-16c61.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=soldierwallet-16c61
VITE_FIREBASE_STORAGE_BUCKET=soldierwallet-16c61.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=896637134400
VITE_FIREBASE_APP_ID=
